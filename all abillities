local function clearSuggestions()
    for _, child in ipairs(suggestionFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
end

searchBar:GetPropertyChangedSignal("Text"):Connect(function()
    local query = string.lower(searchBar.Text)
    clearSuggestions()

    if query ~= "" then
        local yPos = 0

        for _, wordData in ipairs(words) do
            local wordName = string.lower(wordData.name)

            if string.sub(wordName, 1, #query) == query then
                local btn = Instance.new("TextButton")

                btn.Size = UDim2.new(1, 0, 0, 25)
                btn.Position = UDim2.new(0, 0, 0, yPos)
                btn.Text = wordData.name
                btn.Parent = suggestionFrame

                btn.MouseButton1Click:Connect(function()
                    wordData.action()
                end)

                yPos += 25
            end
        end
    end
end)

toggleButton.MouseButton1Click:Connect(function()
    mainFrame.Visible = not mainFrame.Visible
    toggleButton.Text = mainFrame.Visible and "Close Search" or "Open Search"
end)
