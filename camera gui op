local function createButton(text,pos)

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0.4,0,0,35)
	button.Position = pos
	button.BackgroundColor3 = Color3.fromRGB(70,120,255)
	button.Text = text
	button.TextColor3 = Color3.fromRGB(255,255,255)
	button.Font = Enum.Font.GothamBold
	button.TextSize = 13
	button.Parent = frame


	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0,8)
	c.Parent = button


	return button
end



local frontButton = createButton(
	"Front 8",
	UDim2.new(0.07,0,0.7,0)
)


local backButton = createButton(
	"Behind 8",
	UDim2.new(0.53,0,0.7,0)
)



-- Find player using partial name (returns table of players)
local function findPlayers(input)
	input = string.lower(input)
	local matches = {}

	if input == "all" then
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				table.insert(matches, player)
			end
		end
		return matches
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local username = string.lower(player.Name)
			if string.sub(username, 1, #input) == input then
				table.insert(matches, player)
				break
			end
		end
	end

	return matches
end



-- Target function - now handles multiple targets
local function targetPlayer(offset)
	local targets = findPlayers(box.Text)

	for _, target in ipairs(targets) do
		if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
			local hrp = target.Character.HumanoidRootPart
			local position = hrp.CFrame * CFrame.new(0, 0, offset)

			CameraEvent:FireServer({
				cf = position
			})
		end
	end
end



-- LOOP SYSTEM

local frontLoop = false
local backLoop = false


local function startLoop(offset, check)

	while check() do
		targetPlayer(offset)
		task.wait()
	end
end



frontButton.MouseButton1Click:Connect(function()

	-- toggle off
	if frontLoop then
		frontLoop = false
		frontButton.Text = "Front 8"
		return
	end


	-- disable other loop
	backLoop = false
	backButton.Text = "Behind 7"


	frontLoop = true
	frontButton.Text = "Stop Front"


	task.spawn(function()
		startLoop(-12,function()
			return frontLoop
		end)
	end)

end)



backButton.MouseButton1Click:Connect(function()

	-- toggle off
	if backLoop then
		backLoop = false
		backButton.Text = "Behind 8"
		return
	end


	-- disable other loop
	frontLoop = false
	frontButton.Text = "Front 12"


	backLoop = true
	backButton.Text = "Stop Behind"


	task.spawn(function()
		startLoop(8,function()
			return backLoop
		end)
	end)

end)
end)

