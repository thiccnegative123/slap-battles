local function createButton(text,pos)

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0.4,0,0,35)
	button.Position = pos
	button.BackgroundColor3 = Color3.fromRGB(70,120,255)
	button.Text = text
	button.TextColor3 = Color3.fromRGB(255,255,255)
	button.Font = Enum.Font.GothamBold
	button.TextSize = 13
	button.Parent = frame


	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0,8)
	c.Parent = button


	return button
end



local frontButton = createButton(
	"Front 8",
	UDim2.new(0.07,0,0.7,0)
)


local backButton = createButton(
	"Behind 8",
	UDim2.new(0.53,0,0.7,0)
)



-- Find player using partial name
local function findPlayer(input)

	input = string.lower(input)

	for _,player in ipairs(Players:GetPlayers()) do
		
		if player ~= LocalPlayer then
			
			local username = string.lower(player.Name)

			if string.sub(username,1,#input) == input then
				return player
			end
		end
	end

	return nil
end



local function targetPlayer(offset)

	local target = findPlayer(box.Text)

	if target
	and target.Character
	and target.Character:FindFirstChild("HumanoidRootPart") then
		
		local hrp = target.Character.HumanoidRootPart

		local position = hrp.CFrame * CFrame.new(0,0,offset)

		CameraEvent:FireServer({
			cf = position
		})
	end
end



frontButton.MouseButton1Click:Connect(function()

	frontActive = not frontActive
	backActive = false

	if frontActive then
    local StarterGui = game:GetService("StarterGui")

StarterGui:SetCore("SendNotification", {
	Title = "Target",
