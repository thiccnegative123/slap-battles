backButton.MouseButton1Click:Connect(function()

	backActive = not backActive
	frontActive = false

	if backActive then
    local StarterGui = game:GetService("StarterGui")

StarterGui:SetCore("SendNotification", {
	Title = "Target",
	Text = "press q to fire",
	Duration = 3
})
		backButton.Text = "Behind ON"
	else
    local StarterGui = game:GetService("StarterGui")

StarterGui:SetCore("SendNotification", {
	Title = "Target",
	Text = "Behind mode deactivated!",
	Duration = 3
})
		backButton.Text = "Behind 8"
	end

	frontButton.Text = "Front 8"

end)

UserInputService.InputBegan:Connect(function(input, processed)

	if processed then return end

	if input.KeyCode == Enum.KeyCode.Q then
		
		if frontActive then
			targetPlayer(-8)
		end

		if backActive then
			targetPlayer(8)
		end
		
	end

end)
